# ============================================================
#  ธัญกิจ ปุ๋ยภัณฑ์ AI WEB — ตัวอย่างไฟล์ตั้งค่า
# ------------------------------------------------------------
#  หมายเหตุ: ปกติไม่ต้องใส่ key ที่นี่ก็ได้
#  เพราะเว็บมีหน้า "ตั้งค่า" ให้กรอก API key แล้วเก็บไว้ในเครื่อง (localStorage)
#  ไฟล์นี้มีไว้เผื่ออยาก deploy แล้วตั้ง key เป็นค่าเริ่มต้นฝั่ง server
#  วิธีใช้: คัดลอกไฟล์นี้เป็น .env.local แล้วเติมค่า
# ============================================================

# --- LLM (เลือกใส่เฉพาะตัวที่ใช้) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- เสียงพากย์ (TTS) — ไม่ใส่ก็ได้ ระบบ fallback ใช้เสียงในเบราว์เซอร์ ---
ELEVENLABS_API_KEY=
GOOGLE_TTS_API_KEY=

# --- ตัวละครพูด / อวตาร (ออปชัน) ---
HEYGEN_API_KEY=
DID_API_KEY=
