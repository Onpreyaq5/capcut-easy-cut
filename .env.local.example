# ===== ตั้งค่าส่งอีเมลยืนยัน (OTP) =====
# ก็อปไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง (ห้าม commit .env.local ขึ้น git)
#
# วิธีใช้กับ Gmail (แนะนำ ฟรี):
#  1) เปิด 2-Step Verification ในบัญชี Google
#  2) สร้าง App Password ที่ https://myaccount.google.com/apppasswords (ได้รหัส 16 หลัก)
#  3) กรอกด้านล่าง
EASYCUT_SMTP_HOST=smtp.gmail.com
EASYCUT_SMTP_PORT=465
EASYCUT_SMTP_USER=your-email@gmail.com
EASYCUT_SMTP_PASS=xxxxxxxxxxxxxxxx
EASYCUT_MAIL_FROM=your-email@gmail.com

# ถ้าไม่ตั้งค่าเหล่านี้ ระบบจะพิมพ์รหัส OTP ในคอนโซลของเซิร์ฟเวอร์แทน (สำหรับทดสอบในเครื่อง)

# ===== ถอดเสียงบนคลาวด์ (ไม่ต้องมี Python) =====
# สมัคร Groq ฟรีที่ https://console.groq.com/keys แล้วใส่คีย์ -> เว็บจะถอดเสียงผ่าน Groq อัตโนมัติ
# ถ้าไม่ใส่ จะใช้ faster-whisper ในเครื่องแทน (ต้องมี Python)
EASYCUT_GROQ_PLACEHOLDER=
# GROQ_API_KEY=gsk_...

# ===== ฐานข้อมูลจริง (Supabase) — จำเป็นตอน deploy บน Vercel =====
# ถ้าไม่ตั้ง 2 ค่านี้ ระบบจะเก็บไฟล์ในเครื่อง (ใช้ได้เฉพาะรันในเครื่อง)
# ตั้งแล้วจะเก็บบน Supabase แทน -> ข้อมูลไม่หายเวลา deploy
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...   # service_role key (ความลับ! ห้ามเปิดเผย/ห้ามใส่ฝั่งหน้าเว็บ)

# ===== รับเงินสมาชิกด้วย PromptPay QR =====
EASYCUT_PROMPTPAY_ID=0652387451          # เบอร์พร้อมเพย์รับเงิน
EASYCUT_PROMPTPAY_NAME=นายณัฐฤกษ์ ขอคตสำโรง
