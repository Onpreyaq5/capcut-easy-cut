    "@types/qrcode": "^1.5.6",
    "busboy": "^1.6.0",
    "clsx": "2.1.1",
    "file-saver": "2.0.5",
    "framer-motion": "11.5.6",
    "jszip": "3.10.1",
    "lucide-react": "0.451.0",
    "next": "^16.2.10",
    "nodemailer": "^9.0.3",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
