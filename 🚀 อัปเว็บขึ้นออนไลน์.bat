@echo off
chcp 65001 >nul
title อัปเว็บธัญกิจขึ้นออนไลน์ (Vercel)
cd /d "%~dp0"

echo ============================================
echo    อัปเว็บธัญกิจขึ้นออนไลน์ (Vercel) — ฟรี
echo ============================================
echo.
echo  *** ครั้งแรกเท่านั้น: ต้องล็อกอินก่อน ***
echo   1) จะมีรายการเด้งขึ้น ใช้ลูกศรขึ้น/ลง เลือก "Continue with Email"
echo      แล้วกด Enter   (ถ้ามี GitHub จะเลือก GitHub ก็ได้)
echo   2) พิมพ์อีเมล Gmail ของเฟริส์ แล้วกด Enter
echo   3) เปิดอีเมล กดยืนยันลิงก์จาก Vercel  แล้วกลับมาหน้านี้
echo.
echo  *** จากนั้นจะถาม 4-5 ข้อ — กด Enter ไปเรื่อยๆ ทุกข้อ ***
echo      (ตอบค่าเริ่มต้นทั้งหมด ไม่ต้องพิมพ์อะไร)
echo.
echo  เสร็จแล้วจะได้ลิงก์เว็บถาวร เช่น  https://thanyakij-ai-web.vercel.app
echo.
pause

where vercel >nul 2>nul
if errorlevel 1 (
  echo กำลังติดตั้ง Vercel ครั้งแรก...
  call npm install -g vercel
)

vercel --prod

echo.
echo ================================================================
echo   เสร็จแล้ว! ดูบรรทัด  Production: https://....vercel.app
echo   นั่นคือลิงก์เว็บถาวรของเฟริส์ — เปิดได้ทุกที่ ส่งลูกค้าได้เลย
echo ================================================================
echo.
echo  อยากอัปเดตเว็บครั้งหน้า: ดับเบิลคลิกไฟล์นี้อีกครั้ง
pause
